            }
          ]
        },
        {
          "name": "GET Product by ID (with populate)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{url}}/products/{{productId}}",
              "host": ["{{url}}"],
              "path": ["products", "{{productId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Category contains detail instead of just ID\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.product.category).to.be.an('object');",
                  "    pm.expect(jsonData.data.product.category.name).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
