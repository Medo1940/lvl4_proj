            },
            "url": {
              "raw": "{{url}}/products",
              "host": ["{{url}}"],
              "path": ["products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.status === \"success\" && jsonData.data.product) {",
